<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LLM Settings"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Provider Selection -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="AI Provider"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

        <AutoCompleteTextView
            android:id="@+id/providerDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Model Selection -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Model (e.g. gpt-4o-mini)"
        android:layout_marginTop="@dimen/spacing_md"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/modelInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="gpt-4o-mini" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Temperature -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Temperature: 0.7"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:layout_marginTop="@dimen/spacing_lg" />

    <com.google.android.material.slider.Slider
        android:id="@+id/temperatureSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0"
        android:valueTo="2"
        android:value="0.7"
        android:stepSize="0.1" />

    <!-- Max Tokens -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Max Tokens (default: 2048)"
        android:layout_marginTop="@dimen/spacing_md"
        style="@style/WidgetMaterial3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/maxTokensInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="2048" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Top P -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Top P: 0.9"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:layout_marginTop="@dimen/spacing_lg" />

    <com.google.android.material.slider.Slider
        android:id="@+id/topPSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0"
        android:valueTo="1"
        android:value="0.9"
        android:stepSize="0.05" />

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveLlmSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save LLM Settings"
        android:layout_marginTop="@dimen/spacing_xl" />

</LinearLayout>