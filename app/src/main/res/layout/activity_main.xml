<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorSurface">

        <!-- AppBar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:elevation="@dimen/elevation_md">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorSurfaceVariant"
                android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
                app:title="AutoPhone"
                app:titleTextColor="?attr/colorOnSurfaceVariant"
                app:subtitleTextColor="?attr/colorOnSurfaceVariant"
                app:popupTheme="@style/ThemeOverlay.Material3.Light">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectModelButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="?attr/listPreferredItemHeight"
                    android:layout_gravity="end"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:text="AI Model"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:maxWidth="@dimen/spacing_28"
                    android:ellipsize="end"
                    android:singleLine="true"
                    app:backgroundTint="?attr/colorSurface"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="@dimen/spacing_1"
                    app:cornerRadius="@dimen/radius_sm" />

            </androidx.appcompat.widget.Toolbar>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingBottom="@dimen/spacing_xs"
                android:text="Ready"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorTertiary"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Fragment container — fills space between appbar and bottom nav -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Navigation container with rounded corners -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xs">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="@dimen/elevation_md"
                app:strokeWidth="0dp">


                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottomNav"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nav_bar_height"
                    android:background="@android:color/transparent"
                    app:menu="@menu/bottom_nav_menu"
                    app:itemTextColor="@color/subtext1"
                    app:itemIconTint="@color/primary"
                    app:itemActiveIndicatorStyle="@style/SuperPowers.NavIndicator"
                    app:labelVisibilityMode="unlabeled" />


            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </LinearLayout>

    <!-- NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="@dimen/drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="?attr/colorSurfaceVariant"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/nav_drawer_menu"
        app:itemTextColor="?attr/colorOnSurface"
        app:itemIconTint="?attr/colorPrimary" />

</androidx.drawerlayout.widget.DrawerLayout>
