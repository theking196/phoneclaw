<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="@dimen/elevation_sm"
        app:titleTextColor="?attr/colorOnSurfaceVariant"
        app:title="Settings"
        app:titleTextAppearance="@style/TextAppearance.Material3.HeadlineSmall" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xxl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Appearance section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorPrimary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_xs" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Theme"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <Spinner
                        android:id="@+id/themeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="?attr/listPreferredItemHeight"
                        android:background="?attr/colorSurfaceVariant"
                        android:paddingStart="@dimen/spacing_md"
                        android:clipToPadding="false" />

                    <!-- LLM Settings Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openLLMSettings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI Model Settings"
                        android:layout_marginTop="@dimen/spacing_lg" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Configuration section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI CONFIGURATION"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorPrimary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_xs" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your AI Provider"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connect your API key to enable automation."
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfigureAI"
                        android:layout_width="match_parent"
                        android:layout_height="?attr/listPreferredItemHeight"
                        android:text="Configure AI Key"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        app:backgroundTint="?attr/colorPrimary"
                        android:textColor="?attr/colorOnPrimary"
                        app:cornerRadius="@dimen/radius_md" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Behaviour section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BEHAVIOUR"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorPrimary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:paddingStart="@dimen/spacing_xs" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Sandbox switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Execution Sandbox"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Show a preview before running scripts"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="@dimen/spacing_xs" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/sandboxSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Agent loop switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Agent Loop Mode"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Multi-step AI reasoning (requires API key)"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="@dimen/spacing_xs" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/agentLoopSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Ollama switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ollama (On-Device AI)"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use local Ollama instead of cloud AI&#10;(faster, private, requires Ollama app)"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:lineSpacingMultiplier="1.3" />

                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/ollamaSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>