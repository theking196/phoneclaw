<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingEnd="@dimen/spacing_xl"
    android:paddingStart="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs">

    <!-- Avatar -->
    <TextView
        android:layout_width="@dimen/touch_large"
        android:layout_height="@dimen/touch_large"
        android:gravity="center"
        android:text="🤖"
        android:textSize="@dimen/text_lg"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_2"
        android:contentDescription="Agent" />

    <!-- Thinking bubble with pulse animation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/thinkingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface1"
        app:cardCornerRadius="@dimen/radius_lg"
        
        
        
        
        app:cardElevation="@dimen/elevation_sm"
        android:padding="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Three animated dots -->
            <TextView
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_pulse"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_pulse"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_pulse" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thinking..."
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/subtext1"
                android:layout_marginStart="@dimen/spacing_sm" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>