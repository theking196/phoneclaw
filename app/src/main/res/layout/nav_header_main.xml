<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_header_height"
    android:background="?attr/colorSurfaceVariant"
    android:orientation="vertical"
    android:gravity="bottom"
    android:paddingStart="@dimen/spacing_lg"
    android:paddingEnd="@dimen/spacing_lg"
    android:paddingTop="@dimen/spacing_lg"
    android:paddingBottom="@dimen/spacing_lg">

    <!-- Logo / Brand avatar -->
    <TextView
        android:layout_width="@dimen/touch_min"
        android:layout_height="@dimen/touch_min"
        android:text="🤖"
        android:textSize="@dimen/avatar_text_size"
        android:gravity="center"
        android:background="?attr/colorPrimaryContainer"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:clickable="false" />

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutoPhone"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="sans-serif-medium" />

    <!-- Attribution -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Built on PhoneClaw by @rohanarun"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:alpha="0.7"
        android:layout_marginTop="@dimen/spacing_xs" />

</LinearLayout>
