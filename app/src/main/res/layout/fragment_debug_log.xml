<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/spacing_md">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Debug Log"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearLogButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/touch_large"
            android:text="Clear"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            app:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"
            app:cornerRadius="@dimen/radius_lg" />

    </LinearLayout>

    <!-- Scrollable log area -->
    <ScrollView
        android:id="@+id/debugScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurfaceVariant"
        android:padding="@dimen/spacing_md">

        <TextView
            android:id="@+id/debugLogText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No debug logs yet."
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"
            tools:ignore="MissingPrefix" />

    </ScrollView>

</LinearLayout>
