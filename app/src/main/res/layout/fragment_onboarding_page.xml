<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:padding="@dimen/onboarding_input_padding"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="@dimen/spacing_xxl"
        android:paddingBottom="@dimen/spacing_xxl">

        <TextView
            android:id="@+id/pageEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/onboarding_emoji"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:textColor="?attr/colorOnBackground"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_md" />

        <TextView
            android:id="@+id/pageDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:lineSpacingMultiplier="1.4"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="@dimen/elevation_none"
            android:padding="@dimen/onboarding_example_padding">

            <TextView
                android:id="@+id/pageExample"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_md"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:lineSpacingMultiplier="1.5"
                android:fontFamily="monospace" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
