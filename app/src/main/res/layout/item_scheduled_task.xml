<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_none"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Task description (title) -->
        <TextView
            android:id="@+id/taskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="@dimen/spacing_sm"
            tools:text="Turn on flashlight every morning at 7am" />

        <!-- Cron expression (code style) -->
        <TextView
            android:id="@+id/cronExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorPrimary"
            android:background="?attr/colorSurfaceVariant"
            android:padding="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md"
            tools:text="0 7 * * 1-5" />

        <!-- Status label -->
        <TextView
            android:id="@+id/taskStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorTertiary"
            android:layout_marginBottom="@dimen/spacing_md"
            tools:text="Active" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/runNowButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_large"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="Run Now"
                app:backgroundTint="@color/green"
                android:textColor="@color/base"
                app:cornerRadius="@dimen/radius_lg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteTaskButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_large"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Delete"
                app:backgroundTint="@color/red"
                android:textColor="@color/base"
                app:cornerRadius="@dimen/radius_lg" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
