<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:paddingStart="@dimen/spacing_xl"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <!-- User message bubble: MaterialCardView with elevation + ripple -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/messageContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="@dimen/radius_lg"
            
            
            
            
            app:cardElevation="@dimen/elevation_sm"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="@dimen/spacing_sm">

            <TextView
                android:id="@+id/chatText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/chat_bubble_max_width"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnPrimary"
                android:lineSpacingMultiplier="1.3"
                tools:text="Hey! Can you open YouTube for me?" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/chatTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="12:30 PM" />

    </LinearLayout>
</LinearLayout>
