<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        android:background="?attr/colorSurface">

        <!-- Handle -->
        <View
            android:layout_width="@dimen/handle_width"
            android:layout_height="@dimen/spacing_xs"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:background="?attr/colorSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👁 Vision (Moondream)"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Enable Vision toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_lg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Vision AI"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/visionEnabledSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Moondream API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moondream API Key"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/moondreamKeyInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="eyJ..."
                android:inputType="textPassword"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Moondream Endpoint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="API Endpoint"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/moondreamEndpointInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://api.moondream.ai"
                android:inputType="textUri"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Vision Model Dropdown -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vision Model"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <AutoCompleteTextView
                android:id="@+id/visionModelDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Custom Model ID (conditional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/customModelLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/customModelInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Custom model ID"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Query Path -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Query path"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/queryPathInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="/v1/query"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Point Path -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point path"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_xs" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorOutline"
            app:hintTextColor="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/pointPathInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="/v1/point"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="?attr/colorOnSurface"
                android:background="@android:color/transparent" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testVisionButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_large"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="Test Vision"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                app:backgroundTint="?attr/colorSurface"
                app:strokeColor="?attr/colorOutline"
                android:textColor="?attr/colorOnSurface"
                app:cornerRadius="@dimen/radius_lg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveVisionButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_large"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Save"
                app:backgroundTint="?attr/colorPrimary"
                android:textColor="?attr/colorOnPrimary"
                app:cornerRadius="@dimen/radius_lg" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
