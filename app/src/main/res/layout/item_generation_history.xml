<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_sm"
    app:strokeColor="?attr/colorOutline"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- User command row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_md">

            <TextView
                android:id="@+id/userCommand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                tools:text="Open YouTube and search for AI tutorials" />

        </LinearLayout>

        <!-- Generated code block -->
        <TextView
            android:id="@+id/generatedCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/flamingo"
            android:background="?attr/colorSurfaceVariant"
            android:padding="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md"
            android:maxLines="4"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            tools:text="const result = await ai.run('open youtube', {search: 'AI tutorials'});" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/timestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:drawablePadding="@dimen/spacing_sm"
            tools:text="Today at 12:30 PM" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_sm">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/runButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_min"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="Run"
                app:backgroundTint="@color/green"
                android:textColor="@color/base"
                app:cornerRadius="@dimen/radius_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_min"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Edit"
                app:backgroundTint="@color/blue"
                android:textColor="@color/base"
                app:cornerRadius="@dimen/radius_sm" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/scheduleButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/touch_min"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Schedule"
                app:backgroundTint="@color/peach"
                android:textColor="@color/base"
                app:cornerRadius="@dimen/radius_sm" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
